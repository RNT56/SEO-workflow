{
  "name": "seo-polish-workflow",
  "version": "0.1.0",
  "private": true,
  "description": "SEO polish workflow audits, scores, reports and improves websites for modern SEO and AI-agent readiness.",
  "license": "SEE LICENSE IN LICENSE",
  "type": "module",
  "packageManager": "pnpm@11.10.0",
  "scripts": {
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "lint": "eslint .",
    "format": "prettier --check .",
    "format:write": "prettier --write .",
    "audit": "pnpm audit --audit-level low",
    "security:secrets": "node scripts/security/scan-secrets.mjs",
    "security": "pnpm audit && pnpm security:secrets",
    "seo-polish": "pnpm --filter @seo-polish/cli seo-polish",
    "test:fixtures": "node scripts/fixtures/run-fixture-scans.mjs",
    "report:lint": "pnpm --filter @seo-polish/cli seo-polish report lint ./seo-polish-report --strict",
    "standards:update": "pnpm --filter @seo-polish/cli seo-polish standards update --output ./seo-polish-report/standards-registry.json",
    "plan:build": "pnpm --filter @seo-polish/cli seo-polish plan build --report ./seo-polish-report",
    "doctor": "pnpm --filter @seo-polish/cli seo-polish doctor",
    "release:check": "node scripts/release/check-release.mjs",
    "release:pack": "node scripts/release/pack-release.mjs",
    "release:publish:npm": "node scripts/release/publish-npm.mjs",
    "release:verify": "pnpm lint && pnpm typecheck && pnpm test && pnpm build && pnpm test:fixtures && pnpm security && pnpm release:check && pnpm release:pack"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^26.1.0",
    "eslint": "^10.6.0",
    "prettier": "^3.9.4",
    "turbo": "^2.10.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.1",
    "vitest": "^4.1.9"
  }
}
