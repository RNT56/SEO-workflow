{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://seo-polish.dev/schemas/finding.schema.json",
  "type": "object",
  "required": [
    "id",
    "title",
    "category",
    "severity",
    "confidence",
    "status",
    "impact",
    "rootCause",
    "evidence",
    "affectedUrls",
    "affectedTemplates",
    "recommendation",
    "remediation",
    "safeToAutoFix",
    "approvalRequired",
    "validation"
  ],
  "properties": {
    "id": { "type": "string" },
    "title": { "type": "string" },
    "severity": { "enum": ["critical", "high", "medium", "low", "info"] },
    "confidence": { "type": "number", "minimum": 0, "maximum": 100 },
    "evidence": { "type": "array", "minItems": 1 },
    "validation": { "type": "array", "minItems": 1 }
  }
}
